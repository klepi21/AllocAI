AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
NEXT_PUBLIC_VAULT_ADDRESS=0xYOUR_DEPLOYED_VAULT_ADDRESS
NEXT_PUBLIC_KITE_RPC=https://rpc.gokite.ai/

# Lucid withdraw orchestration endpoint (provided by Lucid/support integration)
LUCID_WITHDRAW_ENDPOINT=https://your-lucid-endpoint.example.com/withdraw
LUCID_WITHDRAW_API_KEY=

# Optional tuning
AGENT_POLL_INTERVAL_MS=15000
AGENT_START_BLOCK_OFFSET=250

# APR signal checker tuning (twice-daily job)
APR_MIN_DELTA_BPS=25
APR_MIN_TVL_USD=5000000
APR_FEED_URL=https://yields.llama.fi/pools
LUCID_KITE_APR_FALLBACK=5.85
LUCID_AVAX_APR_FALLBACK=6.5
LUCID_KITE_TVL_FALLBACK=25000000
LUCID_AVAX_TVL_FALLBACK=12000000
LUCID_AVAX_APR_FALLBACK_BPS=650

# Enable real reallocation (Kite -> Avalanche signal strategy) when APR delta threshold is met
APR_EXECUTE_REALLOCATION=false
REALLOCATION_PROTOCOL=Lucid / Avalanche Signal
REALLOCATION_CHAIN=Avalanche

